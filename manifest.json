{
  "manifest_version": 3,
  "name": "YouTube CC Translator",
  "version": "1.5.7",
  "description": "YouTube CC sync with side panel translations and centered video overlay.",
  "permissions": ["storage", "sidePanel", "tabs"],
  "host_permissions": [
    "*://www.youtube.com/*",
    "https://translate.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["pinyin-pro.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "YouTube CC Translator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
